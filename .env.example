# Application
APP_NAME="Permission-Aware Enterprise GraphRAG Assistant"
ENVIRONMENT=development
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL + pgvector
# Local dev (host machine): localhost
# Docker container-to-container: use service name `postgres`
DATABASE_URL=postgresql+psycopg://graphrag:graphrag@localhost:5432/graphrag

# Redis
# Local dev (host machine): localhost
# Docker container-to-container: use service name `redis`
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=paegr

# Neo4j
# Local dev (host machine): localhost
# Docker container-to-container: use service name `neo4j`
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# JWT
JWT_SECRET_KEY=change-me-local-dev-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# RAG
EMBEDDING_DIMENSIONS=64
EMBEDDING_MODE=mock
# local embedding backend: ollama | sentence-transformers
LOCAL_EMBEDDING_BACKEND=ollama
# for ollama backend, use an embedding model such as nomic-embed-text
# for sentence-transformers backend, use a model id such as sentence-transformers/all-MiniLM-L6-v2
LOCAL_EMBEDDING_MODEL=nomic-embed-text
LOCAL_EMBEDDING_BASE_URL=http://host.docker.internal:11434
LOCAL_EMBEDDING_TIMEOUT_SECONDS=8
QA_TOP_K=5
ENABLE_PGVECTOR_SQL_RETRIEVAL=true
PROMPT_VERSION=mvp-2026-05
PERMISSION_POLICY_VERSION=rbac-v1

# Redis cache TTL
CACHE_TTL_SECONDS=1200
CACHE_REFUSAL_TTL_SECONDS=300

# LLM generator mode: mock | ollama | openai-compatible
# Keep mock by default so tests/CI do not depend on external model services.
LLM_MODE=mock
# OpenAI-compatible generator settings
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-with-real-key-in-local-env
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30
# Ollama generator settings
LLM_OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_OLLAMA_MODEL=qwen2.5:7b-instruct
LLM_OLLAMA_TIMEOUT_SECONDS=30

# Local lightweight router.
LOCAL_ROUTER_MODE=rules
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_ROUTER_MODEL=qwen2.5:0.5b-instruct
OLLAMA_ROUTER_TIMEOUT_SECONDS=8

# Startup behavior
SEED_ON_STARTUP=true
SYNC_NEO4J_ON_STARTUP=false
UVICORN_RELOAD=true
