APP_NAME=Permission-Aware Enterprise GraphRAG Assistant
APP_ENV=demo
ENVIRONMENT=demo
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

API_PORT=8000
WEB_PORT=5173

POSTGRES_USER=graphrag
POSTGRES_PASSWORD=graphrag
POSTGRES_DB=graphrag
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://graphrag:graphrag@postgres:5432/graphrag

REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=paegr
REDIS_PORT=6379

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

JWT_SECRET_KEY=change-me-local-demo
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

EMBEDDING_DIMENSIONS=64
EMBEDDING_MODE=mock
LOCAL_EMBEDDING_BACKEND=sentence-transformers
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_BASE_URL=http://host.docker.internal:11434
LOCAL_EMBEDDING_TIMEOUT_SECONDS=8

QA_TOP_K=5
ENABLE_PGVECTOR_SQL_RETRIEVAL=true
PROMPT_VERSION=mvp-2026-05
PERMISSION_POLICY_VERSION=rbac-v1

CACHE_TTL_SECONDS=1200
CACHE_REFUSAL_TTL_SECONDS=300

LLM_MODE=mock
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_OLLAMA_MODEL=qwen2.5:7b-instruct
LLM_OLLAMA_TIMEOUT_SECONDS=30

LOCAL_ROUTER_MODE=rules
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_ROUTER_MODEL=qwen2.5:0.5b-instruct
OLLAMA_ROUTER_TIMEOUT_SECONDS=8
OLLAMA_MODEL=qwen2.5:7b-instruct

SEED_ON_STARTUP=true
SYNC_NEO4J_ON_STARTUP=true
UVICORN_RELOAD=false
